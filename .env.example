# =========================================================================
# CONFIGURACIÓN DE PRODUCCIÓN - PELUQUERÍA CANINA (CANIN DUVET)
# Copia este archivo como '.env' en la raíz del proyecto para producción.
# =========================================================================

# ─── Configuración de la Base de Datos Externa ────────────────────────────
# Especifica aquí la dirección y credenciales de tu base de datos MySQL 
# que has instalado en tu servidor en la nube (fuera de Docker).
DB_HOST=tu-servidor-ip-o-dominio.com
DB_PORT=3306
DB_USER=usuario_mysql
DB_PASSWORD=contrasena_segura
DB_NAME=peluqueria_canina

# ─── URLs del Sistema ─────────────────────────────────────────────────────
# FRONTEND_URL: URL pública desde donde tus clientes accederán a la app.
# VITE_API_URL: URL pública de la API del backend. Debe apuntar al puerto 8080 del host.
FRONTEND_URL=http://tu-servidor-ip-o-dominio.com
VITE_API_URL=http://tu-servidor-ip-o-dominio.com:8080/api

# ─── Entorno ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
